extends ../layout/no-header

block variables 
  - let pageTitle = 'Settings'
  - let user = [{avatar: "../assets/user.svg", firstName: "Milana", secondName: 'Ivanova',  displayName: "Sara Bernar", login: 'sara', password: '1234'}];

block content
  a(class="exit" href="sign-in.pug" title="chat")
    img(src='../assets/arrow-exit.svg' class="transformArrow"  alt="exit")
  div.wrapperSettings
    div.wrapperAvatar
      img(src='../assets/user.svg' class="userPhoto"  alt="user")
      img(src='../assets/add-photo.svg'  alt="add")
      p avatar
    form.regForm
      each i in user
        div.wraperInput
          div.label First name
          input(type='text' name='firstName' value=i.firstName)
        div.wraperInput
          div.label Second name
          input(type='text' name='secondName' value=i.secondName)
        div.wraperInput
          div.label Display name
          input(type='text' name='displayName' value=i.displayName)
        div.wraperInput
          div.label Login
          input(type='text' name='login' value=i.login)
        div.wraperInput
          div.label Old password
          input(type='text' name='old-password')
        div.wraperInput
          div.label New password
          input(type='text' name='new-password')
      button(class="settingsSubmitButton" type="submit" formaction="index.pug")
        p Save


      


